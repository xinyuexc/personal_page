---
import { siteConfig } from '../site';
import { withBase } from '../utils/paths';
---

<footer class="site-footer">
  <div class="site-shell footer-shell">
    <div>
      <p class="footer-title">{siteConfig.name}</p>
      <p class="footer-copy">
        A simple portfolio-in-progress for research, insights, and data science roles.
      </p>
    </div>

    <div class="footer-links">
      <a href={`mailto:${siteConfig.email}`}>Email</a>
      <a href={siteConfig.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a href={siteConfig.github} target="_blank" rel="noreferrer">GitHub</a>
      <a href={withBase('rss.xml')}>RSS</a>
    </div>
  </div>
</footer>
