---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article class="project-card card-surface">
  <p class="card-eyebrow">Project</p>
  <h3>
    <a href={withBase(`projects/${project.slug}/`)}>{project.data.title}</a>
  </h3>
  <p class="card-summary">{project.data.summary}</p>

  <div class="pill-row">
    {project.data.methods.slice(0, 3).map((method) => <span class="pill">{method}</span>)}
  </div>

  <ul class="bullet-list">
    {project.data.outcomes.slice(0, 2).map((outcome) => <li>{outcome}</li>)}
  </ul>
</article>
