---
import MainLayout from '../layouts/MainLayout.astro';
import { focusAreas, homeHighlights, siteConfig, timeline } from '../site';
import { withBase } from '../utils/paths';
---

<MainLayout
  title={siteConfig.title}
  description="A minimalist personal site for a marketing researcher moving toward data science and insights roles."
>
  <section class="hero-shell">
    <div class="hero-panel">
      <p class="eyebrow">Marketing Research x Data Science</p>
      <h1 class="hero-title">A simple portfolio, built around the work I want to do next.</h1>
      <p class="lead">
        I spent seven years in marketing research at companies including Kantar and MetrixLab /
        Toluna, then completed a master’s in data science. This site is a quiet home for the
        projects and writing I am building as I move toward roles that combine research, analysis,
        and clear communication.
      </p>

      <ul class="detail-list">
        {homeHighlights.map((item) => <li>{item}</li>)}
      </ul>

      <div class="link-row">
        <a class="button-link" href={withBase('about/')}>About me</a>
        <a class="text-link" href={withBase('projects/')}>Projects</a>
        <a class="text-link" href={withBase('writing/')}>Writing</a>
        <a class="text-link" href={`mailto:${siteConfig.email}`}>Email</a>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-panel">
      <p class="eyebrow">Direction</p>
      <h2 class="section-title">The kind of work I want to grow into.</h2>
      <div class="focus-grid">
        {focusAreas.map((area) => (
          <article class="card-surface">
            <h3>{area.title}</h3>
            <p class="card-summary">{area.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-panel">
      <p class="eyebrow">In progress</p>
      <h2 class="section-title">The portfolio will stay small and honest.</h2>
      <p class="content-intro">
        I would rather add a small number of real projects than fill the site with work that
        overstates where I am today. The project and writing sections are ready, but I am keeping
        them intentionally light until the first pieces are complete.
      </p>
      <div class="link-row">
        <a class="text-link" href={withBase('projects/')}>Open projects</a>
        <a class="text-link" href={withBase('writing/')}>Open writing</a>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="about-panel">
      <p class="eyebrow">Path</p>
      <h2 class="section-title">A research foundation, followed by a deliberate technical step.</h2>
      <ol class="timeline-list">
        {timeline.map((item) => (
          <li class="timeline-item">
            <span class="card-eyebrow">{item.period}</span>
            <strong>{item.label}</strong>
            <p class="meta-copy">{item.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>
</MainLayout>
