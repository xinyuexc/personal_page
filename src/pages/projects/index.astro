---
import MainLayout from '../../layouts/MainLayout.astro';
import { withBase } from '../../utils/paths';

const projectCategories = [
  {
    label: 'Data Analysis & Engineering',
    items: [
      {
        title: 'Netflix Catalog Strategy Analysis',
        summary:
          'A business-oriented case study that uses public Netflix title data to analyze catalog structure, evolution, and strategic patterns beyond standard EDA.',
        href: 'projects/netflix-catalog-strategy-analysis/',
      },
      {
        title: 'Coming soon',
        summary:
          'Placeholder text placeholder text placeholder text.',
        href: 'projects/data-analysis-engineering-data-quality-monitoring/',
      },
    ],
  },
  {
    label: 'Data Science',
    items: [
      {
        title: 'Predicting Fall Risk from Motion Data',
        summary:
          'My master’s thesis project: building and evaluating a motion-based fall risk prediction pipeline using 3D skeleton data and transfer learning.',
        href: 'projects/predicting-fall-risk-assessment-from-motion-data/',
      },
      {
        title: 'Supply Chain Optimization for Food Distribution',
        summary:
          'A decision-oriented optimization project that uses linear programming to design a cost-minimizing food supply chain and show which constraints matter most in real-world operations.',
        href: 'projects/supply-chain-optimization-for-food-distribution/',
      },
    ],
  },
  {
    label: 'Market Research',
    items: [
      {
        title: 'Coming soon',
        summary:
          'Placeholder text placeholder text placeholder text.',
        href: 'projects/market-research-consumer-segment-opportunity/',
      },
      {
        title: 'Coming soon',
        summary:
          'Placeholder text placeholder text placeholder text.',
        href: 'projects/market-research-brand-tracking-insights/',
      },
    ],
  },
];
---

<MainLayout
  title="Projects"
  description="A focused selection of projects showing how I approach different problem types and deliver practical outcomes."
>
  <section class="content-shell projects-shell">
    <div class="content-panel projects-panel">
      <div class="content-header projects-header">
        <h1 class="page-title projects-title">My Projects</h1>
        <p class="lead">
          Here are a few real projects I’ve worked on — a small selection to give a sense of how I
          approach problems, apply my skills, and turn ideas into practical outcomes.
        </p>
      </div>

      <div class="projects-category-stack">
        {
          projectCategories.map((category) => (
            <section class="project-category-block">
              <p class="content-kicker">{category.label}</p>
              <div class="focus-grid skills-grid projects-list">
                {category.items.map((item) => (
                  <article class="card-surface skill-item">
                    <h3>
                      <a class="project-title-link" href={withBase(item.href)}>{item.title}</a>
                    </h3>
                    <p class="card-summary">{item.summary}</p>
                  </article>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>
