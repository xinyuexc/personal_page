---
import { getCollection } from 'astro:content';

import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { sortByFeaturedRank } from '../../utils/content';

const hasProjectFiles =
  Object.keys(import.meta.glob('/src/content/projects/**/*.{md,mdx}')).length > 0;
const projects = hasProjectFiles ? sortByFeaturedRank(await getCollection('projects')) : [];
---

<MainLayout
  title="Projects"
  description="A placeholder page for future portfolio projects."
>
  <section class="content-shell">
    <div class="content-panel">
      <div class="content-header">
        <h1 class="page-title">A few real projects will live here, but not before they are ready.</h1>
        <p class="lead">
          This page is intentionally quiet for now. The plan is to add a small number of portfolio
          projects that feel honest and complete, rather than filling the site with work that has
          not truly been done yet.
        </p>
      </div>

      {
        projects.length > 0 ? (
          <div class="list-grid">
            {projects.map((project) => <ProjectCard project={project} />)}
          </div>
        ) : (
          <div class="card-surface empty-state">
            <strong>No published projects yet.</strong>
            <p class="meta-copy">
              Case studies will be added here as they are completed and written up properly.
            </p>
          </div>
        )
      }
    </div>
  </section>
</MainLayout>
