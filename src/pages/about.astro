---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig, timeline, workingStyle } from '../site';
---

<MainLayout
  title="About"
  description="Background, working style, and role focus across marketing research, insights, and data science."
>
  <section class="content-shell">
    <div class="about-panel">
      <p class="eyebrow">About</p>
      <h1 class="page-title">Research training, client discipline, and a newer technical toolkit.</h1>
      <p class="lead">
        My background is rooted in marketing research, where I spent seven years designing
        quantitative studies, handling client questions, and turning findings into narratives
        stakeholders could use. After that foundation, I completed a master’s in data science to
        deepen the analytical side of my work.
      </p>
      <p class="content-intro">
        I am not trying to present myself as having already done everything in this next chapter.
        The point of this site is simpler than that: to show the background I already have, the
        direction I am moving in, and the work I will add as it becomes real.
      </p>
      <ul class="detail-list">
        {workingStyle.map((item) => <li>{item}</li>)}
      </ul>
      <div class="link-row">
        <a class="text-link" href={`mailto:${siteConfig.email}`}>Email</a>
        <a class="text-link" href={siteConfig.linkedin} target="_blank" rel="noreferrer">
          LinkedIn
        </a>
        <a class="text-link" href={siteConfig.github} target="_blank" rel="noreferrer">
          GitHub
        </a>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="about-panel">
      <p class="eyebrow">Experience</p>
      <h2 class="section-title">What shaped how I work.</h2>
      <ol class="timeline-list">
        {timeline.map((item) => (
          <li class="timeline-item">
            <span class="card-eyebrow">{item.period}</span>
            <strong>{item.label}</strong>
            <p class="meta-copy">{item.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section-shell">
    <div class="content-panel">
      <p class="eyebrow">What I am looking for</p>
      <h2 class="section-title">Roles where research and analysis meet.</h2>
      <ul class="detail-list">
        <li>
          Research or insights work where strong survey foundations, synthesis, and stakeholder
          storytelling still matter.
        </li>
        <li>
          Teams that want someone with research experience who is actively deepening the technical
          side of the work.
        </li>
        <li>
          A role that values domain experience, curiosity, and strong communication rather than
          expecting years of formal data science titles on day one.
        </li>
      </ul>
    </div>
  </section>
</MainLayout>
