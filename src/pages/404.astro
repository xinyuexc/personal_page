---
import MainLayout from '../layouts/MainLayout.astro';
import { withBase } from '../utils/paths';
---

<MainLayout title="Page not found" description="The page you were looking for does not exist.">
  <section class="content-shell">
    <div class="content-panel">
      <div class="content-header">
        <p class="content-kicker">404</p>
        <h1 class="page-title">This page drifted out of the portfolio.</h1>
        <p class="lead">
          The link may be old, or the page may have moved while the site was being refined.
        </p>
      </div>

      <div class="link-row">
        <a class="button-link" href={withBase()}>Go home</a>
        <a class="text-link" href={withBase('projects/')}>Browse projects</a>
        <a class="text-link" href={withBase('writing/')}>Read the writing</a>
      </div>
    </div>
  </section>
</MainLayout>
